# Copy this file to .env.local and fill in your values.

# Required: a random secret string used to sign session cookies.
# Generate one at: https://www.uuidgenerator.net/
BETTER_AUTH_SECRET=your-random-secret-here

# Optional: PostgreSQL connection string.
# Without this the app runs in memory-only mode (data resets on restart).
# Free databases: https://neon.tech  or  https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/dbname
